<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Vérifier un document</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0f1f6b;
    --blue-flag:#002654;
    --red-flag:#ed2939;
    --gold:#f5c518;
    --paper:#fbfaf7;
    --ink:#1a1a1a;
    --muted:#6b6f76;
    --line:#e3e1db;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    min-height:100vh;
    display:flex;
    align-items:flex-start;
    justify-content:center;
    background:var(--paper);
    font-family:'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    padding:40px 20px;
  }
  .app{ width:380px; }
 
  .topbar{
    display:flex;
    align-items:center;
    gap:14px;
    padding:0 4px 24px;
  }
  .back-btn{
    width:36px;height:36px;
    border-radius:50%;
    background:#fff;
    border:1px solid var(--line);
    display:flex;align-items:center;justify-content:center;
    text-decoration:none;
    color:var(--ink);
    flex-shrink:0;
  }
  .page-title{
    font-family:'Baloo 2', sans-serif;
    font-weight:700;
    font-size:20px;
    color:#111;
  }
 
  .intro{
    font-size:13.5px;
    color:var(--muted);
    line-height:1.5;
    margin:0 0 22px;
  }
 
  .upload-zone{
    background:#fff;
    border:2px dashed #d6d6d0;
    border-radius:16px;
    height:180px;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:8px;
    cursor:pointer;
    margin-bottom:20px;
    transition:border-color .15s ease;
  }
  .upload-zone:hover{ border-color:var(--navy); }
  .upload-zone .icon{
    font-size:28px;
    color:var(--navy);
  }
  .upload-zone .label{
    font-size:13.5px;
    color:var(--muted);
  }
  .upload-zone .filename{
    font-size:13px;
    color:#111;
    font-weight:600;
    display:none;
    padding:0 20px;
    text-align:center;
    word-break:break-all;
  }
  .upload-zone.has-file .icon,
  .upload-zone.has-file .label{ display:none; }
  .upload-zone.has-file .filename{ display:block; }
 
  .verify-btn{
    width:100%;
    padding:15px;
    background:var(--navy);
    color:#fff;
    border:none;
    border-radius:14px;
    font-size:15px;
    font-weight:700;
    font-family:'Baloo 2', sans-serif;
    cursor:pointer;
  }
  .verify-btn:disabled{
    background:#c6cadd;
    cursor:not-allowed;
  }
 
  .result{
    margin-top:20px;
    background:#fff;
    border:1px solid var(--line);
    border-radius:14px;
    padding:18px;
    display:none;
    text-align:center;
  }
  .result.show{ display:block; }
  .result .badge{
    width:46px;height:46px;
    margin:0 auto 10px;
    border-radius:50%;
    background:#e7f6ec;
    color:#1e9b4c;
    display:flex;align-items:center;justify-content:center;
    font-size:22px;
  }
  .result h4{
    margin:0 0 4px;
    font-size:15.5px;
    color:#111;
  }
  .result p{
    margin:0;
    font-size:12.5px;
    color:var(--muted);
  }
 
  .home-link{
    display:inline-block;
    margin-top:22px;
    font-size:13.5px;
    font-weight:600;
    color:var(--navy);
    text-decoration:none;
  }
  .home-link:hover{ text-decoration:underline; }
</style>
</head>
<body>
 
<div class="app">
 
  <div class="topbar">
    <a class="back-btn" href="france-identite-app.html">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </a>
    <span class="page-title">Vérifier un document</span>
  </div>
 
  <a class="home-link" href="france-identite-app.html">← Retour à l'accueil</a>
 
  <p class="intro">Importez un justificatif généré depuis l'application pour contrôler son authenticité et sa validité.</p>
 
  <div class="upload-zone" id="uploadZone">
    <div class="icon">📄</div>
    <div class="label">Importer un document</div>
    <div class="filename" id="filename"></div>
  </div>
  <input type="file" id="fileInput" style="display:none">
 
  <button class="verify-btn" id="verifyBtn" disabled>Vérifier le document</button>
 
  <div class="result" id="result">
    <div class="badge" id="badge">✓</div>
    <h4 id="resultTitle">Document authentique</h4>
    <p id="resultText">Ce justificatif a bien été émis par France Identité et est toujours valide.</p>
  </div>
 
</div>
 
<script>
  const uploadZone = document.getElementById('uploadZone');
  const fileInput = document.getElementById('fileInput');
  const filenameEl = document.getElementById('filename');
  const verifyBtn = document.getElementById('verifyBtn');
  const result = document.getElementById('result');
 
  uploadZone.addEventListener('click', () => fileInput.click());
 
  fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    filenameEl.textContent = file.name;
    uploadZone.classList.add('has-file');
    verifyBtn.disabled = false;
    result.classList.remove('show');
  });
 
  verifyBtn.addEventListener('click', () => {
    result.classList.add('show');
  });
</script>
 
</body>
</html>