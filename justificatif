<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Générer un justificatif d'identité</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0f1f6b;
    --blue-flag:#002654;
    --red-flag:#ed2939;
    --gold:#f5c518;
    --paper:#fbfaf7;
    --ink:#1a1a1a;
    --muted:#6b6f76;
    --line:#e3e1db;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    min-height:100vh;
    display:flex;
    align-items:flex-start;
    justify-content:center;
    background:var(--paper);
    font-family:'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    padding:40px 20px;
  }
  .app{ width:380px; }
 
  .topbar{
    display:flex;
    align-items:center;
    gap:14px;
    padding:0 4px 24px;
  }
  .back-btn{
    width:36px;height:36px;
    border-radius:50%;
    background:#fff;
    border:1px solid var(--line);
    display:flex;align-items:center;justify-content:center;
    text-decoration:none;
    color:var(--ink);
    flex-shrink:0;
  }
  .page-title{
    font-family:'Baloo 2', sans-serif;
    font-weight:700;
    font-size:20px;
    color:#111;
  }
 
  .intro{
    font-size:13.5px;
    color:var(--muted);
    line-height:1.5;
    margin:0 0 22px;
  }
 
  .doc-option{
    display:flex;
    align-items:center;
    gap:14px;
    background:#fff;
    border:1px solid var(--line);
    border-radius:14px;
    padding:14px 16px;
    margin-bottom:14px;
    cursor:pointer;
    transition:border-color .15s ease;
  }
  .doc-option:hover{
    border-color:var(--navy);
  }
  .doc-option.selected{
    border-color:var(--navy);
    box-shadow:0 0 0 2px rgba(15,31,107,.12);
  }
  .doc-icon{
    width:42px;height:42px;
    border-radius:10px;
    background:var(--navy);
    color:#fff;
    display:flex;align-items:center;justify-content:center;
    font-size:18px;
    flex-shrink:0;
  }
  .doc-text h3{
    margin:0 0 2px;
    font-size:15px;
    color:#111;
  }
  .doc-text p{
    margin:0;
    font-size:12px;
    color:var(--muted);
  }
  .radio{
    margin-left:auto;
    width:20px;height:20px;
    border-radius:50%;
    border:2px solid #cfd2d8;
    flex-shrink:0;
    position:relative;
  }
  .doc-option.selected .radio{
    border-color:var(--navy);
  }
  .doc-option.selected .radio::after{
    content:"";
    position:absolute;
    inset:3px;
    border-radius:50%;
    background:var(--navy);
  }
 
  .generate-btn{
    width:100%;
    margin-top:12px;
    padding:15px;
    background:var(--navy);
    color:#fff;
    border:none;
    border-radius:14px;
    font-size:15px;
    font-weight:700;
    font-family:'Baloo 2', sans-serif;
    cursor:pointer;
  }
  .generate-btn:disabled{
    background:#c6cadd;
    cursor:not-allowed;
  }
 
  .result{
    margin-top:20px;
    background:#fff;
    border:1px solid var(--line);
    border-radius:14px;
    padding:16px;
    display:none;
    text-align:center;
  }
  .result.show{ display:block; }
  .result .check{
    width:44px;height:44px;
    margin:0 auto 10px;
    border-radius:50%;
    background:#e7f6ec;
    color:#1e9b4c;
    display:flex;align-items:center;justify-content:center;
    font-size:22px;
  }
  .result h4{
    margin:0 0 4px;
    font-size:15px;
    color:#111;
  }
  .result p{
    margin:0;
    font-size:12.5px;
    color:var(--muted);
  }
 
  .home-link{
    display:inline-block;
    margin-top:22px;
    font-size:13.5px;
    font-weight:600;
    color:var(--navy);
    text-decoration:none;
  }
  .home-link:hover{ text-decoration:underline; }
</style>
</head>
<body>
 
<div class="app">
 
  <div class="topbar">
    <a class="back-btn" href="france-identite-app.html">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </a>
    <span class="page-title">Justificatif d'identité</span>
  </div>
 
  <a class="home-link" href="france-identite-app.html">← Retour à l'accueil</a>
 
  <p class="intro">Choisissez le type de justificatif à générer. Il remplacera vos photocopies papier pour vos démarches.</p>
 
  <div class="doc-option selected" data-name="Justificatif d'identité">
    <div class="doc-icon">🪪</div>
    <div class="doc-text">
      <h3>Justificatif d'identité</h3>
      <p>Valable pour la plupart des démarches courantes.</p>
    </div>
    <div class="radio"></div>
  </div>
 
  <div class="doc-option" data-name="Justificatif de domicile">
    <div class="doc-icon">🏠</div>
    <div class="doc-text">
      <h3>Justificatif de domicile</h3>
      <p>Basé sur l'adresse enregistrée sur votre titre.</p>
    </div>
    <div class="radio"></div>
  </div>
 
  <div class="doc-option" data-name="Attestation de majorité">
    <div class="doc-icon">🔞</div>
    <div class="doc-text">
      <h3>Attestation de majorité</h3>
      <p>Prouve votre majorité sans révéler votre date de naissance.</p>
    </div>
    <div class="radio"></div>
  </div>
 
  <button class="generate-btn" id="genBtn">Générer le justificatif</button>
 
  <div class="result" id="result">
    <div class="check">✓</div>
    <h4 id="resultTitle">Justificatif généré</h4>
    <p>Valable 1 heure, à usage unique.</p>
  </div>
 
</div>
 
<script>
  const options = document.querySelectorAll('.doc-option');
  const genBtn = document.getElementById('genBtn');
  const result = document.getElementById('result');
  const resultTitle = document.getElementById('resultTitle');
 
  options.forEach(opt => {
    opt.addEventListener('click', () => {
      options.forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      result.classList.remove('show');
    });
  });
 
  genBtn.addEventListener('click', () => {
    const selected = document.querySelector('.doc-option.selected');
    const name = selected ? selected.dataset.name : 'Justificatif';
    resultTitle.textContent = name + ' généré';
    result.classList.add('show');
  });
</script>
 
</body>
</html>